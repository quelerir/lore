# Production environment for docker-compose.prod.yml
#
#   cp .env.prod.example .env.prod   # then fill in real values
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# This file is passed ONLY via the --env-file flag; it populates every ${...}
# interpolation in docker-compose.prod.yml. Connects to EXTERNAL authentik +
# PostgreSQL.

# --- Image version ---------------------------------------------------------
# Registry is fixed in the compose anchor (cr.selcloud.ru/adventum/lore-*);
# this tag selects which build to pull.
LORE_VERSION=latest

# --- Public URLs / ports ---------------------------------------------------
# Browser-facing URL of the chat backend (used for the OAuth redirect_uri).
# Must match the VITE_CHAINLIT_URL baked into the frontend image at build time.
CHAINLIT_PUBLIC_URL=https://chat.example.com
# Host ports published by compose (left side host : right side container).
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- External chainlit persistence DB (PostgreSQL) -------------------------
# Already provisioned; schema from lore-core/services/lore-chat/init/schema.sql
# must already be applied.
CHAINLIT_DB_HOST=postgres.internal
CHAINLIT_DB_PORT=5432
CHAINLIT_DB_USER=chainlit
CHAINLIT_DB_PASSWORD=change-me
CHAINLIT_DB_NAME=chainlit

# --- External toast data DB (PostgreSQL) — optional ------------------------
# Source data for SQL/table answers. Leave blank to disable the SQL tool.
TOAST_DB_HOST=
TOAST_DB_PORT=5432
TOAST_DB_USER=
TOAST_DB_PASSWORD=
TOAST_DB_NAME=

# --- Chainlit secrets (generate strong random values) ----------------------
CHAINLIT_AUTH_SECRET=change-me-32-bytes-min
CHAINLIT_JWT_SECRET=change-me-32-bytes-min
CHAINLIT_JWT_AUDIENCE=chainlit
CHAINLIT_JWT_ISSUER=datacraft

# --- External authentik (SSO) ----------------------------------------------
# Single public base URL of the external authentik. compose derives the
# authorize/token/userinfo endpoints from it.
AUTHENTIK_PUBLIC_URL=https://sso.example.com
# OAuth client provisioned in authentik for this app.
AUTHENTIK_CLIENT_ID=lore-chainlit
AUTHENTIK_CLIENT_SECRET=change-me
# Read by Chainlit directly (optional overrides / scopes).
OAUTH_GENERIC_SCOPES=openid profile email
OAUTH_GENERIC_USER_IDENTIFIER=preferred_username

# --- Model provider --------------------------------------------------------
MODEL_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MAX_TOKENS=64000
# Only used when MODEL_PROVIDER=ollama.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3

# --- Observability (optional) ----------------------------------------------
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
