# Скопируй в .env и поправь под себя.
# Почти все значения имеют рабочие дефолты в docker-compose.yml — исключение
# OPENROUTER_API_KEY (пустой, задать обязательно при MODEL_PROVIDER=openrouter).
# Пустые переменные ниже можно оставить пустыми — тогда берётся дефолт compose
# (а для OPENROUTER_API_KEY/TOAST_DATABASE_URL пусто = фича выключена).

# URL Chainlit-бэкенда, каким его видит браузер
CHAINLIT_PUBLIC_URL=http://localhost:8000

# Порты, публикуемые на хосте
FRONTEND_PORT=3000
BACKEND_PORT=8000

# --- Модель / провайдер ---
# openrouter (по умолчанию) | ollama (локальный фолбэк)
MODEL_PROVIDER=openrouter
# Ключ OpenRouter — ОБЯЗАТЕЛЕН при MODEL_PROVIDER=openrouter (иначе запросы падают)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Ollama (запущена на хосте, не в compose) — нужна только при MODEL_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3

# --- TOAST-таблицы (query_document_tables) ---
# Read-only DSN к внешней БД loreagent_test. Пусто — агенту доступен только
# калькулятор; задан — включается инструмент таблиц (сотрудники, грейды, документы).
# Эту БД compose не поднимает.
TOAST_DATABASE_URL=

# --- Postgres истории чатов (chainlit-db, поднимается compose) ---
CHAINLIT_DB_USER=chainlit
CHAINLIT_DB_PASSWORD=chainlit
CHAINLIT_DB_NAME=chainlit

# Секрет собственных сессий Chainlit (сгенерируй: chainlit create-secret)
CHAINLIT_AUTH_SECRET=dev-only-auth-secret-change-me-32b!

# JWT-тикеты (должны совпадать со стороной, выдающей тикеты)
CHAINLIT_JWT_SECRET=dev-only-secret-change-me-32-bytes!
CHAINLIT_JWT_AUDIENCE=chainlit
CHAINLIT_JWT_ISSUER=datacraft

# --- authentik (SSO) ---
# Host-порт authentik (9100, чтобы не конфликтовать с datacraft-app на 9000)
AUTHENTIK_PORT=9100
# Browser-facing URL authentik; должен согласовываться с AUTHENTIK_PORT
AUTHENTIK_PUBLIC_URL=http://localhost:9100
AUTHENTIK_SECRET_KEY=dev-only-authentik-secret-key-change-me
# Пароль пользователя akadmin (сеется при первом старте)
AUTHENTIK_BOOTSTRAP_PASSWORD=admin
# API-токен для bootstrap-скрипта (сеется при первом старте)
AUTHENTIK_BOOTSTRAP_TOKEN=dev-only-bootstrap-api-token-change-me
# OAuth2-клиент, создаваемый bootstrap-скриптом для Chainlit
AUTHENTIK_CLIENT_ID=lore-chainlit
AUTHENTIK_CLIENT_SECRET=dev-only-oauth-client-secret-change-me
# Slug и имя приложения lore в authentik (создаются bootstrap-скриптом)
AUTHENTIK_APP_SLUG=lore
AUTHENTIK_APP_NAME=Lore Chat

# Postgres самого authentik (authentik-db, поднимается compose)
AUTHENTIK_DB_USER=authentik
AUTHENTIK_DB_PASSWORD=authentik
AUTHENTIK_DB_NAME=authentik

# --- Generic OAuth (Chainlit <- authentik) ---
OAUTH_GENERIC_SCOPES=openid profile email
OAUTH_GENERIC_USER_IDENTIFIER=preferred_username
