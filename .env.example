# Скопируй в .env и поправь под себя. Все значения имеют дефолты в docker-compose.yml.

# Провайдер чата во фронтенде: mock (демо без бэкенда) | chainlit
CHAT_PROVIDER=mock
# URL Chainlit-бэкенда, каким его видит браузер
CHAINLIT_PUBLIC_URL=http://localhost:8000

# Порты, публикуемые на хосте
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Ollama (запущена на хосте, не в compose)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3

# Секрет собственных сессий Chainlit (сгенерируй: chainlit create-secret)
CHAINLIT_AUTH_SECRET=dev-only-auth-secret-change-me-32b!

# JWT-тикеты (должны совпадать со стороной, выдающей тикеты)
CHAINLIT_JWT_SECRET=dev-only-secret-change-me-32-bytes!
CHAINLIT_JWT_AUDIENCE=chainlit
CHAINLIT_JWT_ISSUER=datacraft
